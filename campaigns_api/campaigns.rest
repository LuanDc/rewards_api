### Campaigns API REST Client
### Base URL
@baseUrl = http://localhost:4000/api
@contentType = application/json

### Tenant Authorization (change this to test different tenants)
@tenantId = tenant-abc123

### Variables (will be set by responses)
@campaignId =

###################
### Campaigns
###################

### Create a new campaign
# @name createCampaign
POST {{baseUrl}}/campaigns
Authorization: Bearer {{tenantId}}
Content-Type: {{contentType}}

{
  "campaign": {
    "name": "Summer Campaign 2026",
    "status": "not_started"
  }
}

### Create campaign with dates
POST {{baseUrl}}/campaigns
Authorization: Bearer {{tenantId}}
Content-Type: {{contentType}}

{
  "campaign": {
    "name": "Winter Campaign 2026",
    "started_at": "2026-01-20T10:00:00.000000Z",
    "finished_at": "2026-03-20T23:59:59.000000Z",
    "status": "not_started"
  }
}

### Create campaign - Validation Error (missing required fields)
POST {{baseUrl}}/campaigns
Authorization: Bearer {{tenantId}}
Content-Type: {{contentType}}

{
  "campaign": {
    "name": ""
  }
}

### Create campaign - Validation Error (name too long)
POST {{baseUrl}}/campaigns
Authorization: Bearer {{tenantId}}
Content-Type: {{contentType}}

{
  "campaign": {
    "name": "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat. Duis aute irure dolor in reprehenderit."
  }
}

### Create campaign - Unauthorized (no auth header)
POST {{baseUrl}}/campaigns
Content-Type: {{contentType}}

{
  "campaign": {
    "name": "Test Campaign"
  }
}

### Get all campaigns for tenant
GET {{baseUrl}}/campaigns
Authorization: Bearer {{tenantId}}
Content-Type: {{contentType}}

### Get specific campaign (replace with actual ID)
GET {{baseUrl}}/campaigns/01964ee0-3a8b-7c9d-8e5f-123456789abc
Authorization: Bearer {{tenantId}}
Content-Type: {{contentType}}

### Update campaign
PUT {{baseUrl}}/campaigns/01964ee0-3a8b-7c9d-8e5f-123456789abc
Authorization: Bearer {{tenantId}}
Content-Type: {{contentType}}

{
  "campaign": {
    "name": "Updated Summer Campaign 2026",
    "status": "active"
  }
}

### Start campaign
POST {{baseUrl}}/campaigns/01964ee0-3a8b-7c9d-8e5f-123456789abc/start
Authorization: Bearer {{tenantId}}
Content-Type: {{contentType}}

### Finish campaign
POST {{baseUrl}}/campaigns/01964ee0-3a8b-7c9d-8e5f-123456789abc/finish
Authorization: Bearer {{tenantId}}
Content-Type: {{contentType}}

### Delete campaign
DELETE {{baseUrl}}/campaigns/01964ee0-3a8b-7c9d-8e5f-123456789abc
Authorization: Bearer {{tenantId}}
Content-Type: {{contentType}}

